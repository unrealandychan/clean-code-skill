<?xml version="1.0"?>
<!--
  Checkstyle configuration — Clean Code + DDD enforcement for Java
  Drop in project root as checkstyle.xml
  Maven: add maven-checkstyle-plugin pointing to this file
  Gradle: add checkstyle plugin with configFile = file("checkstyle.xml")
  Run (Maven): mvn checkstyle:check
  Run (Gradle): ./gradlew checkstyleMain
-->
<!DOCTYPE module PUBLIC
  "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
  "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
  <property name="severity" value="warning"/>
  <property name="fileExtensions" value="java"/>

  <!-- ── File-level checks ─────────────────────────────────────────── -->
  <module name="FileLength">
    <property name="max" value="400"/>
  </module>
  <module name="NewlineAtEndOfFile"/>

  <module name="TreeWalker">

    <!-- ── Meaningful names (Clean Code) ──────────────────────────── -->
    <module name="LocalVariableName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
      <property name="allowOneCharVarInForLoop" value="true"/>
    </module>
    <module name="MemberName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
    </module>
    <module name="MethodName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
    </module>
    <module name="TypeName">
      <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
    </module>
    <module name="PackageName">
      <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
    </module>
    <!-- Flag too-short names (DDD: ubiquitous language) -->
    <module name="AbbreviationAsWordInName">
      <property name="allowedAbbreviationLength" value="2"/>
      <property name="ignoreFinal" value="false"/>
    </module>

    <!-- ── Single responsibility — method length ───────────────────── -->
    <module name="MethodLength">
      <property name="max" value="40"/>
      <property name="countEmpty" value="false"/>
    </module>

    <!-- ── Complexity (Clean Code: shallow nesting) ────────────────── -->
    <module name="CyclomaticComplexity">
      <property name="max" value="10"/>
    </module>
    <module name="NPathComplexity">
      <property name="max" value="50"/>
    </module>
    <module name="NestedIfDepth">
      <property name="max" value="3"/>
    </module>
    <module name="NestedTryDepth">
      <property name="max" value="2"/>
    </module>

    <!-- ── Small interfaces — parameter count ──────────────────────── -->
    <module name="ParameterNumber">
      <property name="max" value="5"/>
    </module>

    <!-- ── Magic numbers ───────────────────────────────────────────── -->
    <module name="MagicNumber">
      <property name="ignoreNumbers" value="-1, 0, 1, 2"/>
      <property name="ignoreAnnotation" value="true"/>
      <property name="ignoreFieldDeclaration" value="true"/>
    </module>

    <!-- ── DDD: class design ───────────────────────────────────────── -->
    <!-- Bloated classes (god objects) -->
    <module name="ClassFanOutComplexity">
      <property name="max" value="20"/>
    </module>
    <!-- Coupling between objects -->
    <module name="ClassDataAbstractionCoupling">
      <property name="max" value="7"/>
    </module>

    <!-- ── Duplication / dead code ─────────────────────────────────── -->
    <module name="UnusedImports"/>
    <module name="UnusedLocalVariable"/>
    <module name="RedundantImport"/>

    <!-- ── Error handling ──────────────────────────────────────────── -->
    <module name="IllegalCatch">
      <property name="illegalClassNames" value="java.lang.Exception, java.lang.Throwable, java.lang.RuntimeException"/>
    </module>
    <module name="EmptyCatchBlock">
      <property name="exceptionVariableName" value="ignored|expected"/>
    </module>

    <!-- ── Comment quality ─────────────────────────────────────────── -->
    <module name="TodoComment">
      <property name="format" value="TODO:|FIXME:|HACK:"/>
      <property name="severity" value="info"/>
    </module>

    <!-- ── Code style ──────────────────────────────────────────────── -->
    <module name="OneStatementPerLine"/>
    <module name="MultipleVariableDeclarations"/>
    <module name="UpperEll"/>
    <module name="ArrayTypeStyle"/>
    <module name="ModifierOrder"/>

  </module>
</module>
